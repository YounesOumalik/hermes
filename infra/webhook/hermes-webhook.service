[Unit]
Description=Hermes Orchestration GitHub Webhook Receiver
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=younes
WorkingDirectory=/opt/hermes-orchestration/webhook
ExecStart=/usr/bin/node /opt/hermes-orchestration/webhook/server.js
Restart=always
RestartSec=5

# Hardening (mode souple)
NoNewPrivileges=true
PrivateTmp=true
MemoryMax=128M

[Install]
WantedBy=multi-user.target
