# ============================================================================
# .env.template — Variables d'environnement pour la stack d'orchestration
# ----------------------------------------------------------------------------
# Copie ce fichier vers .env et remplace les valeurs __XXX__ par des secrets.
# Les secrets automatiques sont générés par scripts/generate-secrets.sh.
# Les clés API doivent être renseignées manuellement.
#
# ⚠️  Ce fichier .env NE DOIT JAMAIS ÊTRE COMMITÉ (voir .gitignore)
#
# 📌 Services actifs par défaut (sans profil) :
#    - open-webui    → Open WebUI principal (port 3000)
#    - postgres      → Base de données (port 127.0.0.1:5432)
#    - redis         → Cache (port 127.0.0.1:6379)
#
# 📌 Services sous profil "legacy" (à démarrer explicitement) :
#    - llm-proxy     → Ancien proxy LLM (format propriétaire)
#      docker compose --profile legacy up -d llm-proxy
#
# 📌 Providers LLM configurés via Open WebUI Admin UI :
#    - MiniMax       → https://api.minimax.io/v1
#    - OpenCode Zen  → https://opencode.ai/zen/v1
#    (voir docs/OPENWEBUI_PROVIDERS.md)
# ============================================================================

# ---------- Secrets générés automatiquement (ne pas éditer) ----------------
N8N_ENCRYPTION_KEY=__N8N_ENCRYPTION_KEY__
JWT_SECRET=__JWT_SECRET__
WEBUI_SECRET_KEY=__JWT_SECRET__
HERMES_SESSION_SECRET=__HERMES_SESSION_SECRET__
HERMES_ADMIN_USERNAME=admin
# Hash scrypt du mot de passe (générer avec : node scripts/generate-admin-password-hash.mjs)
HERMES_ADMIN_PASSWORD_HASH=__HERMES_ADMIN_PASSWORD_HASH__
HERMES_ALLOWED_ORIGINS=https://hermes.example.com
MCP_AUTH_TOKEN=__MCP_AUTH_TOKEN__
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
REDIS_PASSWORD=__REDIS_PASSWORD__

# ---------- Clés API (à renseigner manuellement) ---------------------------
MINIMAX_API_KEY=__MINIMAX_API_KEY__
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

TELEGRAM_BOT_TOKEN=__TELEGRAM_BOT_TOKEN__
ALLOWED_CHAT_ID=__ALLOWED_CHAT_ID__

GITHUB_TOKEN=__GITHUB_TOKEN__

# ---------- Connecteurs Google OAuth ---------------------------------------
# Créez un client OAuth Web dans Google Cloud Console.
# IMPORTANT : ajoutez ces URLs EXACTES dans "Authorized redirect URIs"
# de votre client OAuth (Google Cloud Console → Credentials → OAuth 2.0):
#   - https://agentai.smartefp.com/oauth/oidc/callback   (Open WebUI login)
GOOGLE_CLIENT_ID=__GOOGLE_CLIENT_ID__
GOOGLE_CLIENT_SECRET=__GOOGLE_CLIENT_SECRET__
GOOGLE_REDIRECT_URI=https://agentai.smartefp.com/oauth/oidc/callback

# ---------- Recherche Internet Hermes -------------------------------------
# DuckDuckGo HTML est utilisé par défaut; un endpoint compatible peut être fourni.
HERMES_WEB_SEARCH_URL=https://html.duckduckgo.com/html/

# ---------- Configuration base de données ----------------------------------
POSTGRES_DB=hermes
POSTGRES_USER=younes
# POSTGRES_PASSWORD est généré automatiquement (voir ci-dessus)

# ---------- URLs publiques -------------------------------------------------
N8N_WEBHOOK_URL=http://169.58.30.70:5678
N8N_WEBHOOK_BASE_URL=http://n8n:5678/webhook
